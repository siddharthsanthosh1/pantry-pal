{
  "expo": {
    "name": "PantryPal",
    "slug": "pantry-pal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pantrypal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantrypal.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PantryPal needs camera access to scan food labels.",
        "NSPhotoLibraryUsageDescription": "PantryPal saves photos of your food labels."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.pantrypal.app",
      "permissions": ["CAMERA", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PantryPal to scan food labels with your camera."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2D6A4F"
        }
      ]
    ]
  }
}
